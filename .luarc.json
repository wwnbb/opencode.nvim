{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "path": [
      "?.lua",
      "?/init.lua",
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "workspace": {
    "library": [
      "$VIMRUNTIME",
      "${3rd}/luv/library",
      ".deps/nvim/nui.nvim",
      ".deps/nvim/plenary.nvim"
    ],
    "checkThirdParty": false,
    "ignoreDir": [
      ".git"
    ]
  },
  "diagnostics": {
    "globals": ["vim"],
    "disable": ["lowercase-global"],
    "neededFileStatus": {
      "inject-field": "Any"
    }
  },
  "format": {
    "defaultConfig": {
      "indent_style": "space",
      "indent_size": "2",
      "continuation_indent_size": "2",
      "quote_style": "double",
      "call_arg_parentheses": "always"
    }
  }
}
